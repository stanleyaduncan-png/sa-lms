# Copy this file to .env.local (gitignored) for local development.

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/lms_platform?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Email (invitations - ACC-07, password reset - AUTH-04)
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="CHANGE_ME"
EMAIL_SERVER_PASSWORD="CHANGE_ME"
EMAIL_FROM="no-reply@example.com"

# Object storage (video/document/SCORM assets) - placeholder, finalize during technical design
STORAGE_BUCKET_NAME="CHANGE_ME"
STORAGE_ACCESS_KEY_ID="CHANGE_ME"
STORAGE_SECRET_ACCESS_KEY="CHANGE_ME"

# Invitation expiry (ACC-08), in days
INVITATION_EXPIRY_DAYS=14
